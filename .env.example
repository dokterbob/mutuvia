# Mutuvia — Environment Configuration
# Copy to .env and fill in required values.

# ── App ──
PUBLIC_APP_NAME=Mutuvia
PUBLIC_APP_TAGLINE="Together, we are more."
APP_URL=http://localhost:5173
# REQUIRED in production: min 32 characters, used to sign Better Auth sessions
BETTER_AUTH_SECRET=change-me-to-a-random-secret!!

# ── Database ──
# DB_PROVIDER: 'sqlite' (default) or 'pg'
DB_PROVIDER=sqlite
# SQLite (when DB_PROVIDER=sqlite):
DB_FILE_NAME=sqlite.db
# PostgreSQL (when DB_PROVIDER=pg):
# DATABASE_URL=postgres://mutuvia:mutuvia@localhost:5432/mutuvia

# ── Currency / Unit ──
UNIT_CODE=EUR
PUBLIC_UNIT_SYMBOL=€
PUBLIC_UNIT_DISPLAY_NAME=euro

# ── QR codes ──
QR_TTL_SECONDS=259200             # QR token validity (default: 3 days)
EXPIRED_QR_RETENTION_SECONDS=259200  # how long expired QRs are kept (default: 3 days)
# REQUIRED: min 32 characters, used to sign QR JWTs
QR_JWT_SECRET=change-me-to-a-random-32-char-secret!!

# ── Web Push (optional) ──
# Required for push notifications to backgrounded PWA users.
# Generate keys: bunx web-push generate-vapid-keys
PUBLIC_VAPID_KEY=
PRIVATE_VAPID_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── Prelude (SMS OTP) ──
# Required for production SMS OTP delivery. In dev, OTPs are logged to console.
PRELUDE_API_TOKEN=

# ── SMTP (Email OTP) ──
# Required for production email OTP delivery. In dev, OTPs are logged to console.
# Works with any SMTP provider: Resend, Brevo, Mailgun, Amazon SES, Postmark, etc.
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE=true   # set true for port 465 (implicit TLS); false uses STARTTLS
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mutuvia <noreply@example.com>"

# ── Community ──
PUBLIC_COMMUNITY_DOC_URL=

# ── Sentry (optional) ──
# Set PUBLIC_SENTRY_DSN to enable error tracking and the feedback widget.
# Leave blank (or unset) to disable Sentry entirely.
PUBLIC_SENTRY_DSN=
# Required only for source map uploads in CI (optional):
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
