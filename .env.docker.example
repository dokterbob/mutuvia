# Mutuvia — Docker deployment environment
# Copy to .env before running: docker compose --profile sqlite up
#                           or: docker compose --profile postgres up

# ── Required ──────────────────────────────────────────────────────────────────

# Public URL of your deployment (used in QR links and auth callbacks)
APP_URL=https://your-domain.com

# Secret key for signing QR JWT tokens (min 32 characters)
QR_JWT_SECRET=change-me-to-a-random-32-char-secret!!

# Secret key for Better Auth sessions (min 32 characters)
BETTER_AUTH_SECRET=change-me-to-a-random-secret!!

# ── Database ──────────────────────────────────────────────────────────────────
# For --profile sqlite: no extra config needed (defaults apply)
# For --profile postgres: set DATABASE_URL (password must match POSTGRES_PASSWORD below)
# DATABASE_URL=postgresql://mutuvia:change-me@postgres:5432/mutuvia
# POSTGRES_PASSWORD=change-me

# ── Prelude (SMS & Email OTP) ─────────────────────────────────────────────────
# Required for OTP delivery in production (SMS and email). Without this, OTPs are only logged.
PRELUDE_API_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────
# PORT=3000
# PUBLIC_APP_NAME=Mutuvia
# PUBLIC_APP_TAGLINE="Together, we are more."
# UNIT_CODE=EUR
# PUBLIC_UNIT_SYMBOL=€
# PUBLIC_UNIT_DISPLAY_NAME=euro
# UNIT_DECIMAL_PLACES=2
# QR_TTL_SECONDS=600
# PUBLIC_COMMUNITY_DOC_URL=
# PUBLIC_SENTRY_DSN=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com
