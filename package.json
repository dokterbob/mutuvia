{
	"name": "mutuvia",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "svelte-kit sync || echo '' && git-hooks || echo ''",
		"check": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy cookie preferredLanguage baseLocale && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint . --fix --no-error-on-unmatched-pattern",
		"format": "prettier --write .",
		"test": "bun --bun vitest run",
		"test:unit": "bun --bun vitest",
		"test:e2e": "bun playwright test",
		"test:e2e:ui": "bun playwright test --ui",
		"db:generate:sqlite": "bun drizzle-kit generate --config drizzle.config.sqlite.ts",
		"db:generate:pg": "bun drizzle-kit generate --config drizzle.config.pg.ts",
		"db:generate": "echo 'Use db:generate:sqlite or db:generate:pg'",
		"db:migrate": "bun scripts/migrate.ts",
		"db:seed": "bun scripts/seed.ts",
		"db:push:pg": "bun drizzle-kit push --config drizzle.config.pg.ts",
		"generate-secret": "bun scripts/generate-secret.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@inlang/plugin-m-function-matcher": "^2.2.4",
		"@inlang/plugin-message-format": "^4.4.0",
		"@eslint/js": "^9.39.2",
		"@fontsource-variable/noto-sans": "^5.2.10",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/bun": "^1.3.11",
		"@types/node": "^22",
		"@types/web-push": "^3.6.4",
		"@vite-pwa/assets-generator": "^1.0.2",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.0",
		"better-sqlite3": "^12.8.0",
		"bits-ui": "^2.16.3",
		"bun-git-hooks": "^0.3.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"jsdom": "^29.0.1",
		"jsrepo": "^3.7.0",
		"mode-watcher": "^1.1.0",
		"playwright": "1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"git-hooks": {
		"pre-commit": {
			"staged-lint": {
				"*": "prettier --write --ignore-unknown",
				"**/*.{js,ts}": "eslint --fix --no-error-on-unmatched-pattern"
			}
		},
		"commit-msg": "true"
	},
	"dependencies": {
		"@inlang/paraglide-js": "^2.15.1",
		"@inlang/plugin-m-function-matcher": "^2.2.4",
		"@inlang/plugin-message-format": "^4.4.0",
		"@prelude.so/sdk": "^0.10.0",
		"@sentry/sveltekit": "^10.46.0",
		"@types/qrcode": "^1.5.6",
		"barcode-detector": "^3.1.1",
		"better-auth": "^1.5.6",
		"country-flag-icons": "^1.6.15",
		"drizzle-orm": "^0.45.1",
		"jose": "^6.2.2",
		"qrcode": "^1.5.4",
		"svelte-tel-input": "^3.6.1",
		"web-push": "^3.6.7"
	},
	"patchedDependencies": {
		"bun-git-hooks@0.3.1": "patches/bun-git-hooks@0.3.1.patch"
	}
}
